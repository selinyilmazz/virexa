# Virexa - environment variables
#
# None of these are set to real values here. Copy this file to
# .env.local and fill in real values per service when you're ready to
# connect it.

# --- Site (Production Readiness) ---
# Canonical public origin, no trailing slash (e.g. https://virexa.app).
# Used for metadataBase, OpenGraph/Twitter absolute URLs, robots.txt,
# and sitemap.xml - see src/lib/env.ts. Falls back to
# http://localhost:3000 for local dev; MUST be set in every real
# deployment or canonical URLs and the sitemap will point at localhost.
NEXT_PUBLIC_SITE_URL=

# --- Supabase (Auth, and later: Bookmarks / Profile database) ---
# The URL and anon key must be NEXT_PUBLIC_-prefixed so the browser
# Supabase client (src/lib/supabase/client.ts) can read them - the anon
# key is safe to expose publicly, it's designed for this and is
# constrained by Row Level Security policies on the database side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Plain (non-public) fallbacks also supported for server-only contexts -
# see src/lib/env.ts. Not required if the NEXT_PUBLIC_ versions above are set.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only. NEVER prefix this with NEXT_PUBLIC_ - it bypasses Row
# Level Security and must never reach the browser. Used by
# src/lib/supabase/service-client.ts, which the Runtime layer's
# "database" pipeline step uses to persist articles/AI results/metrics
# (see supabase/migrations/0002_article_storage.sql). Persistence safely
# no-ops until this is set.
SUPABASE_SERVICE_ROLE_KEY=

# --- News providers (see DESIGN.md -> "News Architecture") ---
# NewsAPI.org
NEWS_API_KEY=
# GNews.io
GNEWS_API_KEY=
# TheNewsAPI.com
THENEWS_API_KEY=
# Hacker News (hacker-news.firebaseio.com) - the official, free, public
# Hacker News API. No key required - HackerNewsProvider is always on,
# same as RSS. Nothing to set here.

# --- Stock photo image fallback (see src/lib/news/stock-image-provider.ts) ---
# Stage 3 of the image pipeline: a real, topical, royalty-free stock
# photo search for any article whose RSS/provider image and og:image
# lookup both came up empty, tried in this priority order before the
# local category-placeholder is ever used. All three keys below are
# optional - each provider safely no-ops without its own key, same
# convention as the news provider keys above. Wikimedia Commons needs
# none of these and is always tried regardless, so this stage works out
# of the box even with all three left empty.
# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=
# Unsplash (https://unsplash.com/developers) - use the Access Key, not the Secret Key.
UNSPLASH_ACCESS_KEY=
# Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=

# --- AI Intelligence layer (see src/services/ai) ---
# Set the key for whichever provider AI_PROVIDER points at; the others
# can stay empty. Every AI operation safely no-ops (returns null, never
# throws) until its provider's key is set - see src/services/ai/ai-provider-instance.ts.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Which provider to use: "openai" (default) | "anthropic" | "openrouter"
AI_PROVIDER=
# Model id for the selected provider. Leave empty to use a sensible
# per-provider default (see DEFAULT_AI_MODELS in src/lib/env.ts).
AI_MODEL=
# Per-request timeout, in milliseconds. Default: 15000
AI_TIMEOUT=
# Max tokens requested per AI response. Default: 700
AI_MAX_TOKENS=
# How long a generated AI result stays cached before being regenerated,
# in milliseconds. Default: 86400000 (24h)
AI_CACHE_TTL=

# --- Runtime / Automation layer (see src/runtime) ---
# Master switch. The scheduler never starts on its own even when this
# is "true" - something still has to call runtimeEngine.start() - but
# this is the convention that future callers (a cron trigger, an admin
# action) should check first. Default: false
RUNTIME_ENABLED=
# How often each recurring job runs, in MINUTES (converted to ms
# internally - see src/runtime/config.ts). Defaults shown below.
RSS_INTERVAL=
# Default: 5
NEWSAPI_INTERVAL=
# Default: 10
GNEWS_INTERVAL=
# Default: 10
HN_INTERVAL=
# Default: 5 (Hacker News needs no key, so it runs on the same cadence as RSS)
AI_INTERVAL=
# Default: 15 (drives ai-summary/ai-tag/sentiment/bias-analysis)
CACHE_INTERVAL=
# Default: 5
HEALTH_INTERVAL=
# Default: 1
# Per-attempt job timeout, in milliseconds. Default: 30000
JOB_TIMEOUT=
# Max attempts 