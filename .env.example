# Virexa news infrastructure — environment variables
#
# None of these are required yet. The provider architecture under
# src/services/news is designed to run without any of them configured:
# each provider checks for its own key and no-ops if it's missing.
# Copy this file to .env.local and fill in real values when wiring up
# a real provider (see DESIGN.md -> "News Architecture").

# NewsAPI.org
NEWS_API_KEY=

# GNews.io
GNEWS_API_KEY=

# TheNewsAPI.com
THENEWS_API_KEY=

# Supabase (planned storage for aggregated articles)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# OpenAI (planned use: smarter duplicate detection / AI summaries)
OPENAI_API_KEY=
